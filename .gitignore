# MONITORING DATA (runtime-generated artifacts — never commit)
monitoring/**/reports/
monitoring/**/profiles/
monitoring/**/data/
monitoring/**/storage/

# Prometheus / Grafana persistent volumes
prometheus-data/
grafana-data/

# Evidently HTML/JSON reports fallback rule
**/evidently/**/reports/

# TEMPORARY FILES
tmp/
temp/

# ML DATA — managed by DVC / LakeFS

# Ignore datasets
ml/data/raw/**
ml/data/processed/**
ml/data/interim/**
ml/data/external/**
ml/data/features/**

# Allow DVC pointer files
!ml/data/**/*.dvc

# MODEL ARTIFACTS

ml/models/artifacts/**

# Allow lightweight metrics tracking (optional but recommended)
!ml/models/artifacts/eval_metrics.json


