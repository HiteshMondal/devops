# ML — DATA & MODEL ARTIFACTS
# Managed by DVC / LakeFS — commit only the pointer files, not the data

# Raw and processed datasets (DVC tracks these via *.dvc pointer files)
ml/data/raw/
ml/data/processed/
ml/data/interim/
ml/data/external/
ml/data/features/

# Keep DVC pointer files and config
!ml/data/raw.dvc
!ml/data/**/*.dvc

# Trained model artifacts (large binaries — no value in git)
ml/models/artifacts/

# Common ML model file extensions (belt-and-suspenders)
*.pt
*.pth
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.onnx
*.pb
*.bin
*.safetensors

# DVC
.dvc/cache/
.dvc/tmp/
.dvc/plots/
.dvc/config.local
# NOTE: dvc.lock IS intentionally tracked — do not add it here

# METAFLOW
.metaflow/

